---
import SectionHeading from "@/components/SectionHeading.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const entries = (await getCollection("library")).sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
const counts = {
  book: entries.filter((entry) => entry.data.type === "book").length,
  reading: entries.filter((entry) => entry.data.type === "reading").length,
  thought: entries.filter((entry) => entry.data.type === "thought").length,
};
---

<BaseLayout title="Library | Bijay Khadka" description="Books, reading links, and thoughts from Bijay Khadka.">
  <SectionHeading eyebrow="Library" title="Books, Reading, Thoughts" description="A lower-priority personal area for notes and references I add gradually." />
  <div class="grid gap-5 md:grid-cols-3">
    <a href="/library/books" class="deco-card p-6">
      <p class="deco-kicker">{counts.book} entries</p>
      <h2 class="mt-3 font-display deco-section-title text-2xl text-[var(--text)]">Books</h2>
    </a>
    <a href="/library/reading" class="deco-card p-6">
      <p class="deco-kicker">{counts.reading} entries</p>
      <h2 class="mt-3 font-display deco-section-title text-2xl text-[var(--text)]">Reading List</h2>
    </a>
    <a href="/library/thoughts" class="deco-card p-6">
      <p class="deco-kicker">{counts.thought} entries</p>
      <h2 class="mt-3 font-display deco-section-title text-2xl text-[var(--text)]">Thoughts</h2>
    </a>
  </div>
</BaseLayout>
