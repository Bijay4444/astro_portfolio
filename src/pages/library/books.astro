---
import SectionHeading from "@/components/SectionHeading.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const entries = (await getCollection("library")).filter((entry) => entry.data.type === "book");
---

<BaseLayout title="Books | Bijay Khadka" description="Books from Bijay Khadka's portfolio library.">
  <SectionHeading eyebrow="Library" title="Books" />
  <div class="grid gap-4">
    {entries.map((entry) => (
      <a href={`/library/${entry.id}`} class="deco-card block p-6">
        <p class="deco-kicker">{entry.data.status ?? "Book"}</p>
        <h2 class="mt-3 font-display deco-section-title text-2xl text-[var(--text)]">{entry.data.title}</h2>
        <p class="mt-2 text-[var(--muted-text)]">{entry.data.description}</p>
      </a>
    ))}
  </div>
</BaseLayout>
