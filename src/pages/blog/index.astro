---
import SectionHeading from "@/components/SectionHeading.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const posts = (await getCollection("blog"))
  .filter((post) => !post.data.draft)
  .sort((a, b) => Number(b.data.pubDate ?? 0) - Number(a.data.pubDate ?? 0));
---

<BaseLayout title="Blog | Bijay Khadka" description="Long-form notes on Django, APIs, deployment, and backend systems by Bijay Khadka.">
  <SectionHeading eyebrow="Blog" title="Backend Notes" description="Long-form notes on Django, APIs, deployment, and backend systems. Drafts are kept private until they are edited and published." />

  {posts.length === 0 ? (
    <section class="deco-card max-w-3xl p-8">
      <h2 class="font-display text-2xl text-[var(--text)]">Articles are in progress.</h2>
      <p class="mt-4 leading-8 text-[var(--muted-text)]">
        I am preparing practical notes on Django REST APIs, PostgreSQL performance, Docker deployment, and backend system design. Draft files exist in the repo, but they are not published yet.
      </p>
    </section>
  ) : (
    <div class="grid gap-5">
      {posts.map((post) => (
        <a href={`/blog/${post.id}`} class="deco-card block p-7">
          <p class="deco-kicker">{post.data.category}</p>
          <h2 class="mt-3 font-display deco-section-title text-2xl text-[var(--text)]">{post.data.title}</h2>
          <p class="mt-3 text-[var(--muted-text)]">{post.data.description}</p>
          <div class="mt-4 flex flex-wrap gap-2">
            {post.data.tags.map((tag) => <span class="deco-chip px-2 py-1 text-xs">{tag}</span>)}
          </div>
        </a>
      ))}
    </div>
  )}
</BaseLayout>
